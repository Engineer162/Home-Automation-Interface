{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows (MSVC)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HAI_FETCH_DEPS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "rpi4-aarch64",
      "displayName": "Raspberry Pi 4 (aarch64 cross)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/rpi4-aarch64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/rpi4-aarch64.cmake",
        "HAI_FETCH_DEPS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Release"
    },
    {
      "name": "build-rpi4-aarch64",
      "configurePreset": "rpi4-aarch64",
      "configuration": "Release"
    }
  ]
}
